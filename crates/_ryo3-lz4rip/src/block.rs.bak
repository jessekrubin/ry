//! lz4 block (de)compression
use lz4rip::block::{
    DictCompressor, compress_into, compress_into_with_dict, decompress_into,
    decompress_into_with_dict, get_maximum_output_size,
};
use pyo3::prelude::*;
use ryo3_bytes::{ReadableBuffer, RyBytes};
use ryo3_core::macros::{py_value_err, py_value_error};

use super::Error;

#[pyfunction]
#[pyo3(signature = (data, *, size = true, dictionary = None))]
#[expect(clippy::needless_pass_by_value)]
pub fn lz4_compress_block(
    py: Python<'_>,
    data: ReadableBuffer,
    size: bool,
    dictionary: Option<ReadableBuffer>,
) -> PyResult<RyBytes> {
    let input = data.as_ref();
    let dict = dictionary.as_ref().map(AsRef::as_ref);
    // python-lz4 compatible u32-le uncompressed-size prefix
    let prefix = if size {
        let size = u32::try_from(input.len()).map_err(|_| {
            py_value_error!("LZ4 compression failed: size=True requires input < 4GiB")
        })?;
        Some(size.to_le_bytes())
    } else {
        None
    };
    py.detach(|| {
        let prefix_len = prefix.map_or(0, |p| p.len());
        let mut output = vec![0; prefix_len + get_maximum_output_size(input.len())];
        if let Some(prefix) = prefix {
            output[..prefix_len].copy_from_slice(&prefix);
        }
        let size = if let Some(dict) = dict {
            compress_into_with_dict(input, &mut output[prefix_len..], dict)
        } else {
            compress_into(input, &mut output[prefix_len..])
        }
        .map_err(Error::from)?;
        output.truncate(prefix_len + size);
        Ok(output.into())
    })
}

#[pyfunction]
#[pyo3(signature = (data, size = None, *, dictionary = None))]
#[expect(clippy::needless_pass_by_value)]
pub fn lz4_decompress_block(
    py: Python<'_>,
    data: ReadableBuffer,
    size: Option<usize>,
    dictionary: Option<ReadableBuffer>,
) -> PyResult<RyBytes> {
    let input = data.as_ref();
    let dict = dictionary.as_ref().map(AsRef::as_ref);
    py.detach(|| {
        // `size=None` expects a python-lz4 style u32-le uncompressed-size
        // prefix; an explicit size means a raw block
        let (input, size, size_is_exact) = if let Some(size) = size {
            (input, size, false)
        } else {
            let Some((prefix, rest)) = input.split_first_chunk::<4>() else {
                return py_value_err!(
                    "LZ4 decompression failed: input too short for u32-le size prefix (pass size for raw blocks)"
                );
            };
            let size = u32::from_le_bytes(*prefix) as usize;
            // max lz4 ratio is 255x — reject lying prefixes before allocating
            if size > rest.len().saturating_mul(255) {
                return py_value_err!(
                    "LZ4 decompression failed: size prefix ({size}) impossibly large for {}-byte input",
                    rest.len()
                );
            }
            (rest, size, true)
        };
        let mut output = vec![0; size];
        let written = if let Some(dict) = dict {
            decompress_into_with_dict(input, &mut output, dict)
        } else {
            decompress_into(input, &mut output)
        }.map_err(Error::from)?;
        if size_is_exact && written != size {
            return py_value_err!(
                "LZ4 decompression failed: size prefix ({size}) != decompressed size ({written})"
            );
        }
        output.truncate(written);
        Ok(output.into())
    })
}

enum Lz4BlockCompresser {
    Vanilla(lz4rip::block::Compressor),
    Dict(lz4rip::block::DictCompressor),
}

#[pyclass(name = "Lz4BlockCompressor")]
#[cfg_attr(feature = "ry", pyo3(module = "ry.ryo3"))]
#[derive(Debug)]
pub struct PyLz4BlockCompressor {
    // // why-boxed? `lz4rip::block::DictCompressor` is 64-byte aligned which
    // // causes problemos w/ something in pyo3's pyclass storage/allocation...
    // //
    // // inlining the compressor struct causes this error:
    // // ```
    // // thread '<unnamed>' panicked at 'pyo3-0.29.0/src/pyclass_init.rs:160:18:
    // // misaligned pointer dereference: address must be a multiple of 0x40 but is 0x19ef54173b0
    // // note: run with `RUST_BACKTRACE=1` environment variable to display a backtrace
    // // thread caused non-unwinding panic. aborting.
    // // ```
    // inner: Box<DictCompressor>,
    // why-boxed? `lz4rip::block::DictCompressor` is 64-byte aligned which
    // causes problemos w/ something in pyo3's pyclass storage/allocation...
    //
    // inlining the compressor struct causes this error:
    // ```
    // thread '<unnamed>' panicked at 'pyo3-0.29.0/src/pyclass_init.rs:160:18:
    // misaligned pointer dereference: address must be a multiple of 0x40 but is 0x19ef54173b0
    // note: run with `RUST_BACKTRACE=1` environment variable to display a backtrace
    // thread caused non-unwinding panic. aborting.
    // ```
    inner: Box<DictCompressor>,
}

#[pymethods]
impl PyLz4BlockCompressor {
    #[new]
    #[expect(clippy::needless_pass_by_value)]
    fn new(dictionary: ReadableBuffer) -> Self {
        Self {
            inner: Box::new(DictCompressor::new(dictionary.as_ref())),
        }
    }

    #[expect(clippy::needless_pass_by_value)]
    fn compress(&mut self, py: Python<'_>, data: ReadableBuffer) -> RyBytes {
        let input = data.as_ref();
        py.detach(|| self.inner.compress(input)).into()
    }
}
